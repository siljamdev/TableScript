import stdlib;
import stdnum;

tab testCounter = 0;

doTest(substringTest());
doTest(substringTest2());
doTest(tableDeleteAtTest());
doTest(tableRangeTest());
doTest(tableDeleteTest());
doTest(tableAccessTest());
doTest(tableAccessTest2());
doTest(tableAccessTest3());
doTest(tableFindTest());
doTest(tableFindTest2());
doTest(doTest());
doTest(doTest2());
doTest(forTest());
doTest(forTest2());
doTest(foreachTest());
doTest(dollarTest());

function doTest(result){
	testCounter += 1;
	if(result){
		print("    Test " + testCounter.toNum() + " passed");
	}else{
		error("[X] Test " + testCounter.toNum() + " failed");
	}
}

function substringTest(){
	tab a0 = "Hello World"%;
	tab a1 = a0[0, a0.length - 2];
	
	return a1 == "Hello Wor"%;
}

function substringTest2(){
	tab a0 = "Hello World"%;
	tab a1 = a0[-2, 2];
	
	return a1 == "ld"%;
}

function tableDeleteAtTest(){
	tab a = ["a", "b", "c"];
	a = a.stdlib::deleteAt(1);
	
	return a[1] == "c";
}

function tableRangeTest(){
	tab a = ["a", "b", "c", "d", "e", "f"];
	a = a[-3, 3];
	
	return a^ == "def";
}

function tableDeleteTest(){
	tab a = ["a", "b", "a", "d", "a", "f"];
	a = a.stdlib::deleteAll("a");
	
	return a^ == "bdf";
}

function tableAccessTest(){
	tab a = ["a", "b", "c", "d", "a", "f"];
	
	return a.2 == "c";
}

function tableAccessTest2(){
	tab a = ["a", "b", "a", "d", "a", "f"][-2];
	
	return a == "a";
}

function tableAccessTest3(){
	tab a = ["a", "b", "a", "d", "a", "f"].-2;
	
	return a == "a";
}

function tableFindTest(){
	tab a = ["a", "b", "a", "d", "a", "f"];
	tab b = a.stdlib::indexOf("a");
	
	return b == 0;
}

function tableFindTest2(){
	tab a = ["n", "b", "c", "a", "a", "f"];
	tab b = a.stdlib::indexOf("a");
	
	return b == 3;
}

function doTest(){
	tab a = "0";
	tab b;
	do{
		a = stdnum::sum(a, "1");
		b = stdnum::greater("7", a);
	}while b;
	
	return a == "7";
}

function doTest2(){
	tab a = "0";
	tab b;
	do{
		a = stdnum::sum(a, "1");
		b = stdnum::less("7", a);
	}while !b;
	
	return a == "8";
}

function forTest(){
	tab a = "0";
	tab b;
	while stdnum::less(a, "7"){
		b[a.stdnum::toLen()] = a;
		a = stdnum::sum(a, "1");
	}
	
	return b^ == "0123456";
}

function forTest2(){
	tab a = "3";
	tab b;
	while stdnum::less(a, "7"){
		b[a.stdnum::toLen()] = a;
		a = stdnum::sum(a, "1");
	}
	
	return b^ == "3456";
}

function foreachTest(){
	tab a = [];
	foreach n @ ["a", "b", "c"]{
		tab b = n;
		a += n;
		a += b;
	}
	
	return a == ["a", "a", "b", "b", "c", "c"];
}

function dollarTest(){
	tab a = "test";
	tab b = ["number", "test"];
	tab c = $"hello! this is a {a} and also a {b + "c"}";
	
	return c == "hello! this is a test and also a numbertestc";
}
