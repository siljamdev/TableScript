import stdregex;

function test_anyMatch(){
	return stdregex::anyMatch("193", "[0-9]+");
}

function test_anyMatch2(){
	return stdregex::anyMatch(["a", "193"], "[0-9]+");
}

function test_anyMatch3(){
	return !stdregex::anyMatch(["a", "b"], "[0-9]+");
}

function test_allMatch(){
	return !stdregex::allMatch(["a", "193"], "[0-9]+");
}

function test_firstMatch(){
	return stdregex::firstMatchGroups(["a", "193", "a193"], "([a-z]+)([0-9]+)") == ["a193", "a", "193"];
}

function test_match(){
	return stdregex::match(["a", "193", "a193"], "([a-z]+)([0-9]+)") == ["a193", "a193"];
}

function test_count(){
	return stdregex::countMatches(["a", "193", "a193"], "([a-z]+)([0-9]+)") == 1;
}

function test_replace(){
	return stdregex::replaceMatches(["a", "193", "a193"], "([a-z]+)([0-9]+)", "$2$1") == ["a", "193", "193a"];
}
